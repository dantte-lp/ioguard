FROM oraclelinux:10

LABEL maintainer="ringwall development team"
LABEL description="Development environment for ringwall with wolfSSL and modern C libraries"

# Build arguments for tool versions
ARG CMAKE_VERSION=4.2.3
ARG CLANG_VERSION=22.1.0
# GCC 15 via gcc-toolset-15 (no version ARG needed — from OL10 repos)
ARG SQLITE_VERSION=3520000
ARG SQLITE_YEAR=2026
ARG DOXYGEN_VERSION=1.16.1
ARG UNITY_VERSION=2.6.1
ARG CMOCK_VERSION=2.6.0
ARG CEEDLING_VERSION=1.0.1
ARG WOLFSSL_VERSION=5.8.2
ARG WOLFSENTRY_VERSION=1.6.2
ARG LIBURING_VERSION=2.14
ARG YYJSON_VERSION=0.12.0
ARG LLHTTP_VERSION=9.3.1
ARG CARES_VERSION=1.34.6
ARG MIMALLOC_VERSION=3.2.8
ARG CJSON_VERSION=1.7.19
ARG LIBNFTNL_VERSION=1.3.1
ARG PROTOBUF_C_VERSION=1.5.2
ARG STUMPLESS_VERSION=2.2.0

# Enable CodeReady Builder repo (for -devel packages not in baseos/appstream)
RUN dnf install -y oraclelinux-developer-release-el10 && \
    dnf config-manager --set-enabled ol10_codeready_builder && \
    dnf clean all

# Install base development tools (system gcc needed for libraries that build with default cc)
RUN dnf install -y \
    gcc \
    gcc-c++ \
    make \
    autoconf \
    automake \
    libtool \
    pkgconfig \
    git \
    vim \
    gdb \
    valgrind \
    strace \
    wget \
    curl \
    tar \
    xz \
    bzip2 \
    patch \
    flex \
    bison \
    && dnf clean all

# ═══════════════════════════════════════════════════════
# Compilers (from source / pre-built)
# ═══════════════════════════════════════════════════════

# Install Clang 22.1.0 from pre-built release binary (selective — only needed tools)
# The LLVM tarball is ~6GB extracted; copy only what we need to keep the layer small.
# clang/clang++ are symlinks to clang-N, lld to lld-N, etc. — copy real binaries + symlinks.
RUN cd /tmp && \
    curl -fsSL -o llvm.tar.xz \
        https://github.com/llvm/llvm-project/releases/download/llvmorg-${CLANG_VERSION}/LLVM-${CLANG_VERSION}-Linux-X64.tar.xz && \
    tar xJf llvm.tar.xz && \
    LLVM_DIR=LLVM-${CLANG_VERSION}-Linux-X64 && \
    CLANG_MAJOR=$(echo ${CLANG_VERSION} | cut -d. -f1) && \
    for tool in clang clang++ clang-cl clang-cpp clang-${CLANG_MAJOR} \
                clang-format clang-tidy clang-apply-replacements \
                clang-rename clang-check \
                lld ld.lld ld64.lld wasm-ld \
                llvm-ar llvm-nm llvm-objdump llvm-ranlib llvm-strip \
                llvm-symbolizer llvm-profdata llvm-cov llvm-objcopy \
                llvm-readelf llvm-size llvm-strings llvm-addr2line \
                scan-build scan-view; do \
        [ -e "$LLVM_DIR/bin/$tool" ] && cp -a "$LLVM_DIR/bin/$tool" /usr/local/bin/; \
    done && \
    cp -a $LLVM_DIR/lib/clang /usr/local/lib/ && \
    rm -rf /tmp/LLVM-* /tmp/llvm.tar.xz && \
    ldconfig && \
    clang --version

# Install GCC 15 from gcc-toolset-15 (OL10 appstream, pre-built)
# Provides GCC 15.1.1 at /opt/rh/gcc-toolset-15/root/usr/bin/gcc
RUN dnf install -y \
        gcc-toolset-15-gcc \
        gcc-toolset-15-gcc-c++ \
        gcc-toolset-15-libatomic-devel \
        gcc-toolset-15-libasan-devel \
        gcc-toolset-15-libubsan-devel \
        gcc-toolset-15-libtsan-devel \
        gcc-toolset-15-binutils \
    && dnf clean all && \
    ln -sf /opt/rh/gcc-toolset-15/root/usr/bin/gcc /usr/local/bin/gcc-15 && \
    ln -sf /opt/rh/gcc-toolset-15/root/usr/bin/g++ /usr/local/bin/g++-15 && \
    gcc-15 --version

# Install system dependencies from OL10 repos (baseos + codeready_builder)
RUN dnf install -y \
    pam-devel \
    libseccomp-devel \
    readline-devel \
    lz4-devel \
    libnl3-devel \
    krb5-devel \
    gnutls-devel \
    nettle-devel \
    gmp-devel \
    libtasn1-devel \
    p11-kit-devel \
    openssl-devel \
    openldap-devel \
    gettext-devel \
    libmnl-devel \
    protobuf-devel \
    protobuf-compiler \
    && dnf clean all

# Install code quality and documentation tools
RUN dnf install -y \
    graphviz \
    python3 \
    python3-pip \
    ruby \
    ruby-devel \
    rubygems \
    && dnf clean all

# Install ninja from PyPI (not in OL10 repos)
RUN pip3 install ninja

# Install Ruby gems for Ceedling
RUN gem install --no-document \
    rake \
    thor \
    constructor \
    deep_merge

# Build and install CMake from source
RUN cd /tmp && \
    wget https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}.tar.gz && \
    tar xzf cmake-${CMAKE_VERSION}.tar.gz && \
    cd cmake-${CMAKE_VERSION} && \
    ./bootstrap --prefix=/usr/local --parallel=$(nproc) && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf cmake-*

# Build and install cppcheck from source
RUN cd /tmp && \
    git clone --depth 1 --branch 2.18.3 https://github.com/danmar/cppcheck.git && \
    cd cppcheck && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf cppcheck

# Build and install Doxygen from source
RUN cd /tmp && \
    wget https://github.com/doxygen/doxygen/archive/refs/tags/Release_${DOXYGEN_VERSION//./_}.tar.gz && \
    tar xzf Release_${DOXYGEN_VERSION//./_}.tar.gz && \
    cd doxygen-Release_${DOXYGEN_VERSION//./_} && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf doxygen-* Release_*

# Install Unity testing framework
RUN cd /tmp && \
    wget https://github.com/ThrowTheSwitch/Unity/archive/refs/tags/v${UNITY_VERSION}.tar.gz && \
    tar xzf v${UNITY_VERSION}.tar.gz && \
    cd Unity-${UNITY_VERSION} && \
    mkdir -p /usr/local/include/unity && \
    mkdir -p /usr/local/src/unity && \
    cp src/unity.h src/unity_internals.h /usr/local/include/unity/ && \
    cp src/unity.c /usr/local/src/unity/ && \
    cp -r extras /usr/local/src/unity/ && \
    cd /tmp && rm -rf Unity-* v${UNITY_VERSION}.tar.gz

# Install CMock
RUN cd /tmp && \
    wget https://github.com/ThrowTheSwitch/CMock/archive/refs/tags/v${CMOCK_VERSION}.tar.gz && \
    tar xzf v${CMOCK_VERSION}.tar.gz && \
    cd CMock-${CMOCK_VERSION} && \
    mkdir -p /usr/local/lib/cmock /usr/local/src/cmock && \
    cp -r lib/* /usr/local/lib/cmock/ && \
    cp -r src/* /usr/local/src/cmock/ && \
    cd /tmp && rm -rf CMock-* v${CMOCK_VERSION}.tar.gz

# Install Ceedling
RUN gem install --no-document ceedling -v ${CEEDLING_VERSION}

# ═══════════════════════════════════════════════════════
# Core Crypto & Security
# ═══════════════════════════════════════════════════════

# Build and install wolfSSL from source (GPLv3)
# NOTE: --disable-sp-asm due to GCC 14 register syntax incompatibility
RUN cd /tmp && \
    wget https://github.com/wolfSSL/wolfssl/archive/refs/tags/v${WOLFSSL_VERSION}-stable.tar.gz && \
    tar xzf v${WOLFSSL_VERSION}-stable.tar.gz && \
    cd wolfssl-${WOLFSSL_VERSION}-stable && \
    ./autogen.sh && \
    ./configure \
        --enable-tls13 \
        --enable-dtls \
        --enable-dtls13 \
        --enable-session-ticket \
        --enable-alpn \
        --enable-sni \
        --enable-secure-renegotiation \
        --enable-extended-master \
        --enable-ocsp \
        --enable-crl \
        --enable-aesni \
        --enable-intelasm \
        --disable-oldtls \
        --enable-harden \
        --enable-sp \
        --disable-sp-asm \
        --enable-opensslextra \
        --enable-opensslall \
        --enable-curve25519 \
        --enable-ed25519 \
        --enable-sha3 \
        --enable-shake256 \
        --enable-postauth \
        --enable-hrrcookie \
        --enable-quic \
        --prefix=/usr/local \
        CFLAGS="-std=gnu11 -O2 -g -fstack-protector-strong" \
        LDFLAGS="-Wl,-z,relro -Wl,-z,now" && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf wolfssl-*

# Build and install wolfSentry from source (GPLv2)
# NOTE: -Wno-error=inline for GCC 14 compatibility with v1.6.2
RUN cd /tmp && \
    wget https://github.com/wolfSSL/wolfsentry/archive/refs/tags/v${WOLFSENTRY_VERSION}.tar.gz && \
    tar xzf v${WOLFSENTRY_VERSION}.tar.gz && \
    cd wolfsentry-${WOLFSENTRY_VERSION} && \
    make -j$(nproc) \
        EXTRA_CFLAGS="-O2 -g -fstack-protector-strong -Wno-error=inline" \
        PREFIX=/usr/local && \
    make install PREFIX=/usr/local && \
    ldconfig && \
    cd /tmp && rm -rf wolfsentry-*

