    git clone --depth 1 https://github.com/radcli/radcli.git && \
    cd radcli && \
    touch config.rpath && \
    autoreconf -fi && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf radcli

