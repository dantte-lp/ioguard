# ioguard development image
# Thin layer on top of the shared ioplane-base image.
#
# Build base first:
#   podman build -t ioplane-base:latest \
#     -f /opt/projects/repositories/container-images/tools/ioplane-base/Containerfile .
#
# Build this image:
#   podman build -t ioguard-dev:latest -f deploy/podman/Containerfile .

FROM localhost/ioplane-base:latest

LABEL maintainer="ioguard development team"
LABEL description="Development environment for ioguard with wolfSSL and modern C libraries"

# ═══════════════════════════════════════════════════════
# Build arguments for project-specific library versions
# ═══════════════════════════════════════════════════════

ARG SQLITE_VERSION=3520000
ARG SQLITE_YEAR=2026
ARG CMOCK_VERSION=2.6.0
ARG CEEDLING_VERSION=1.0.1
ARG WOLFSSL_VERSION=5.8.4
ARG WOLFSENTRY_VERSION=1.6.2
ARG LIBURING_VERSION=2.14
ARG YYJSON_VERSION=0.12.0
ARG NGHTTP2_VERSION=1.68.0
ARG NGTCP2_VERSION=1.21.0
ARG NGHTTP3_VERSION=1.15.0
ARG WSLAY_VERSION=1.1.1
ARG CARES_VERSION=1.34.6
ARG MIMALLOC_VERSION=3.2.8
ARG CJSON_VERSION=1.7.19
ARG LIBNFTNL_VERSION=1.3.1
ARG PROTOBUF_C_VERSION=1.5.2
ARG STUMPLESS_VERSION=2.2.0

# ═══════════════════════════════════════════════════════
# System dependencies from OL10 repos
# ═══════════════════════════════════════════════════════

RUN dnf install -y \
    lz4-devel \
    pam-devel \
    libseccomp-devel \
    libmnl-devel \
    nftables-devel \
    libnetfilter_queue-devel \
    protobuf-devel \
    ruby \
    ruby-devel \
    rubygem-rake \
    && dnf clean all

# ═══════════════════════════════════════════════════════
# Ruby: CMock and Ceedling (test frameworks)
# ═══════════════════════════════════════════════════════

RUN gem install ceedling -v "${CEEDLING_VERSION}" && \
    gem install thor deep_merge unicode-display_width && \
    cd /tmp && \
    wget "https://github.com/ThrowTheSwitch/CMock/archive/refs/tags/v${CMOCK_VERSION}.tar.gz" && \
    tar xzf "v${CMOCK_VERSION}.tar.gz" && \
    mkdir -p /usr/local/src/cmock && \
    cp -a "CMock-${CMOCK_VERSION}/src"/* /usr/local/src/cmock/ && \
    cp -a "CMock-${CMOCK_VERSION}/lib"/* /usr/local/lib/ruby/ 2>/dev/null || true && \
    cd /tmp && rm -rf CMock-* "v${CMOCK_VERSION}.tar.gz"

# ═══════════════════════════════════════════════════════
# Core Crypto & Security
# ═══════════════════════════════════════════════════════

# wolfSSL with QUIC support
# NOTE: --disable-sp-asm due to GCC 14 register syntax incompatibility
RUN cd /tmp && \
    wget https://github.com/wolfSSL/wolfssl/archive/refs/tags/v${WOLFSSL_VERSION}-stable.tar.gz && \
    tar xzf v${WOLFSSL_VERSION}-stable.tar.gz && \
    cd wolfssl-${WOLFSSL_VERSION}-stable && \
    ./autogen.sh && \
    ./configure \
        --enable-tls13 \
        --enable-dtls \
        --enable-dtls13 \
        --enable-session-ticket \
        --enable-alpn \
        --enable-sni \
        --enable-secure-renegotiation \
        --enable-extended-master \
        --enable-ocsp \
        --enable-crl \
        --enable-aesni \
        --enable-intelasm \
        --disable-oldtls \
        --enable-harden \
        --enable-sp \
        --disable-sp-asm \
        --enable-opensslextra \
        --enable-opensslall \
        --enable-curve25519 \
        --enable-ed25519 \
        --enable-sha3 \
        --enable-shake256 \
        --enable-postauth \
        --enable-hrrcookie \
        --enable-quic \
        --prefix=/usr/local \
        CFLAGS="-std=gnu11 -O2 -g -fstack-protector-strong" \
        LDFLAGS="-Wl,-z,relro -Wl,-z,now" && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf wolfssl-*

# wolfSentry
# NOTE: -Wno-error=inline for GCC 14 compatibility with v1.6.2
RUN cd /tmp && \
    wget https://github.com/wolfSSL/wolfsentry/archive/refs/tags/v${WOLFSENTRY_VERSION}.tar.gz && \
    tar xzf v${WOLFSENTRY_VERSION}.tar.gz && \
    cd wolfsentry-${WOLFSENTRY_VERSION} && \
    make -j$(nproc) \
        EXTRA_CFLAGS="-O2 -g -fstack-protector-strong -Wno-error=inline" \
        PREFIX=/usr/local && \
    make install PREFIX=/usr/local && \
    ldconfig && \
    cd /tmp && rm -rf wolfsentry-*

# ═══════════════════════════════════════════════════════
# Network & I/O
# ═══════════════════════════════════════════════════════

# liburing
RUN cd /tmp && \
    wget https://github.com/axboe/liburing/archive/refs/tags/liburing-${LIBURING_VERSION}.tar.gz && \
    tar xzf liburing-${LIBURING_VERSION}.tar.gz && \
    cd liburing-liburing-${LIBURING_VERSION} && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf liburing-*

# iohttpparser (pull-based, zero-copy, SIMD HTTP parser — replaces llhttp)
RUN cd /tmp && \
    git clone --depth 1 https://github.com/ioplane/iohttpparser.git && \
    cd iohttpparser && \
    mkdir build && cd build && \
    CC=clang cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DBUILD_TESTING=OFF \
        -DIHTP_BUILD_COMPARE=OFF && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf iohttpparser

# yyjson (required by liboas)
RUN cd /tmp && \
    wget https://github.com/ibireme/yyjson/archive/refs/tags/${YYJSON_VERSION}.tar.gz && \
    tar xzf ${YYJSON_VERSION}.tar.gz && \
    cd yyjson-${YYJSON_VERSION} && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf yyjson-*

# liboas (OpenAPI 3.2 schema library, requires yyjson)
RUN cd /tmp && \
    git clone --depth 1 https://github.com/ioplane/liboas.git && \
    cd liboas && \
    mkdir build && cd build && \
    CC=clang cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DBUILD_TESTING=OFF \
        -DOAS_YAML=OFF && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf liboas

# iojournal (structured logging library)
RUN cd /tmp && \
    git clone --depth 1 https://github.com/ioplane/iojournal.git && \
    cd iojournal && \
    mkdir build && cd build && \
    CC=clang cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DBUILD_TESTING=OFF && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf iojournal

# iohttp HTTP/2+3 dependencies: nghttp2, ngtcp2, nghttp3, wslay, sfparse
RUN dnf install -y brotli-devel && dnf clean all

RUN cd /tmp && \
    wget https://github.com/nghttp2/nghttp2/releases/download/v${NGHTTP2_VERSION}/nghttp2-${NGHTTP2_VERSION}.tar.gz && \
    tar xzf nghttp2-${NGHTTP2_VERSION}.tar.gz && \
    cd nghttp2-${NGHTTP2_VERSION} && \
    mkdir build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr/local -DENABLE_LIB_ONLY=ON && \
    make -j$(nproc) && make install && ldconfig && \
    cd /tmp && rm -rf nghttp2-*

RUN cd /tmp && \
    wget https://github.com/ngtcp2/ngtcp2/releases/download/v${NGTCP2_VERSION}/ngtcp2-${NGTCP2_VERSION}.tar.gz && \
    tar xzf ngtcp2-${NGTCP2_VERSION}.tar.gz && \
    cd ngtcp2-${NGTCP2_VERSION} && \
    mkdir build && cd build && \
    PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/local/lib64/pkgconfig \
    cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr/local -DENABLE_WOLFSSL=ON && \
    make -j$(nproc) && make install && ldconfig && \
    cd /tmp && rm -rf ngtcp2-*

RUN cd /tmp && \
    wget https://github.com/ngtcp2/nghttp3/releases/download/v${NGHTTP3_VERSION}/nghttp3-${NGHTTP3_VERSION}.tar.gz && \
    tar xzf nghttp3-${NGHTTP3_VERSION}.tar.gz && \
    cd nghttp3-${NGHTTP3_VERSION} && \
    mkdir build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr/local -DENABLE_LIB_ONLY=ON && \
    make -j$(nproc) && make install && ldconfig && \
    cd /tmp && rm -rf nghttp3-*

RUN cd /tmp && \
    wget https://github.com/tatsuhiro-t/wslay/releases/download/release-${WSLAY_VERSION}/wslay-${WSLAY_VERSION}.tar.gz && \
    tar xzf wslay-${WSLAY_VERSION}.tar.gz && \
    cd wslay-${WSLAY_VERSION} && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && make install && ldconfig && \
    cd /tmp && rm -rf wslay-*

RUN cd /tmp && \
    git clone --depth 1 https://github.com/ngtcp2/sfparse.git && \
    cp sfparse/sfparse.h /usr/local/include/ && \
    rm -rf /tmp/sfparse

# iohttp (C23 embedded HTTP server — headers and sources available for integration)
# NOTE: iohttp is an application, not an installable library; clone to /usr/local/src
# for header access and source-level integration during ioguard development.
RUN git clone --depth 1 https://github.com/ioplane/iohttp.git /usr/local/src/iohttp

# c-ares
RUN cd /tmp && \
    wget https://github.com/c-ares/c-ares/releases/download/v${CARES_VERSION}/c-ares-${CARES_VERSION}.tar.gz && \
    tar xzf c-ares-${CARES_VERSION}.tar.gz && \
    cd c-ares-${CARES_VERSION} && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf c-ares-*

# libnftnl (OL10 has 1.2.8, missing array overrun fix)
RUN cd /tmp && \
    wget https://www.netfilter.org/projects/libnftnl/files/libnftnl-${LIBNFTNL_VERSION}.tar.xz && \
    tar xJf libnftnl-${LIBNFTNL_VERSION}.tar.xz && \
    cd libnftnl-${LIBNFTNL_VERSION} && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf libnftnl-*

# ═══════════════════════════════════════════════════════
# Data & Configuration
# ═══════════════════════════════════════════════════════

# cJSON
RUN cd /tmp && \
    git clone --depth 1 --branch v${CJSON_VERSION} https://github.com/DaveGamble/cJSON.git && \
    cd cJSON && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DENABLE_CJSON_TEST=OFF && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf cJSON

# protobuf-c
RUN cd /tmp && \
    wget https://github.com/protobuf-c/protobuf-c/releases/download/v${PROTOBUF_C_VERSION}/protobuf-c-${PROTOBUF_C_VERSION}.tar.gz && \
    tar xzf protobuf-c-${PROTOBUF_C_VERSION}.tar.gz && \
    cd protobuf-c-${PROTOBUF_C_VERSION} && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf protobuf-c-*

# tomlc99
RUN cd /tmp && \
    git clone --depth 1 https://github.com/cktan/tomlc99.git && \
    cd tomlc99 && \
    make && \
    make install PREFIX=/usr/local && \
    ldconfig && \
    cd /tmp && rm -rf tomlc99

# ═══════════════════════════════════════════════════════
# System & Memory
# ═══════════════════════════════════════════════════════

# mimalloc
RUN cd /tmp && \
    git clone --depth 1 --branch v${MIMALLOC_VERSION} https://github.com/microsoft/mimalloc.git && \
    cd mimalloc && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DMI_BUILD_TESTS=OFF \
        -DMI_SECURE=ON && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf mimalloc

# ═══════════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════════

# radcli
RUN cd /tmp && \
    git clone --depth 1 https://github.com/radcli/radcli.git && \
    cd radcli && \
    touch config.rpath && \
    autoreconf -fi && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf radcli

# liboath (oath-toolkit) — optional, Savannah mirror may be unreachable
RUN cd /tmp && \
    (wget --timeout=30 https://download.savannah.nongnu.org/releases/oath-toolkit/oath-toolkit-2.6.12.tar.gz && \
    tar xzf oath-toolkit-2.6.12.tar.gz && \
    cd oath-toolkit-2.6.12 && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf oath-toolkit-*) \
    || echo "WARNING: oath-toolkit installation failed (network?) — skipping"

# ═══════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════

# stumpless (RFC 5424 structured logging)
RUN cd /tmp && \
    wget https://github.com/goatshriek/stumpless/archive/refs/tags/v${STUMPLESS_VERSION}.tar.gz && \
    tar xzf v${STUMPLESS_VERSION}.tar.gz && \
    cd stumpless-${STUMPLESS_VERSION} && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DBUILD_TESTING=OFF && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf stumpless-*

# ═══════════════════════════════════════════════════════
# Misc
# ═══════════════════════════════════════════════════════

# linenoise (header-only)
RUN cd /tmp && \
    git clone --depth 1 https://github.com/antirez/linenoise.git && \
    cp linenoise/linenoise.h /usr/local/include/ && \
    cp linenoise/linenoise.c /usr/local/src/ && \
    rm -rf /tmp/linenoise

# ═══════════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════════

# SQLite 3.52.0 (OL10 has 3.46.1 — missing WAL corruption fix)
RUN cd /tmp && \
    curl -fsSL -o sqlite.tar.gz \
        https://www.sqlite.org/${SQLITE_YEAR}/sqlite-autoconf-${SQLITE_VERSION}.tar.gz && \
    tar xzf sqlite.tar.gz && \
    cd sqlite-autoconf-${SQLITE_VERSION} && \
    ./configure \
        --prefix=/usr/local \
        --enable-fts5 \
        CFLAGS="-O2 -DSQLITE_DQS=0 -DSQLITE_THREADSAFE=1 -DSQLITE_DEFAULT_WAL_SYNCHRONOUS=1 \
                -DSQLITE_DEFAULT_MEMSTATUS=0 -DSQLITE_DEFAULT_JOURNAL_SIZE_LIMIT=67108864 \
                -DSQLITE_LIKE_DOESNT_MATCH_BLOBS -DSQLITE_OMIT_DEPRECATED \
                -DSQLITE_OMIT_SHARED_CACHE -DSQLITE_USE_ALLOCA \
                -DSQLITE_ENABLE_FTS5 \
                -DSQLITE_SECURE_DELETE -DSQLITE_ENABLE_COLUMN_METADATA" && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf sqlite-*

# libmdbx
RUN cd /tmp && \
    git clone --depth 50 --branch master https://github.com/erthink/libmdbx.git && \
    cd libmdbx && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DMDBX_BUILD_TOOLS=OFF \
        -DMDBX_BUILD_CXX=OFF && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    cd /tmp && rm -rf libmdbx

# ═══════════════════════════════════════════════════════
# Performance & Dynamic Analysis
# ═══════════════════════════════════════════════════════

# System profilers
RUN dnf install -y \
    perf \
    ltrace \
    && dnf clean all

# tshark + tcpdump
RUN dnf install -y \
    wireshark-cli \
    tcpdump \
    && dnf clean all

# FlameGraph tools
RUN git clone --depth 1 https://github.com/brendangregg/FlameGraph.git /opt/flamegraph && \
    ln -sf /opt/flamegraph/stackcollapse-perf.pl /usr/local/bin/ && \
    ln -sf /opt/flamegraph/flamegraph.pl /usr/local/bin/

# ═══════════════════════════════════════════════════════
# Build Acceleration
# ═══════════════════════════════════════════════════════

RUN mkdir -p /root/.config/ccache && \
    printf "max_size = 2G\ncompression = true\ncompression_level = 6\n" \
        > /root/.config/ccache/ccache.conf

RUN ldconfig

WORKDIR /workspace
CMD ["/bin/bash"]
